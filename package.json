{
  "name": "@ogmara/sdk",
  "version": "0.4.0",
  "description": "Ogmara JS/TS SDK — client library and embeddable widget for the Ogmara platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:widget": "tsup src/widget.ts --format iife --global-name Ogmara --outDir dist --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ogmara",
    "klever",
    "blockchain",
    "chat",
    "decentralized",
    "sdk"
  ],
  "author": "Ogmara Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ogmara/sdk-js"
  },
  "homepage": "https://ogmara.org",
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0"
  }
}
